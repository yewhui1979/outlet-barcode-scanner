<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_back"
        app:navigationIconTint="@color/on_primary"
        app:title="Product Details"
        app:titleTextColor="@color/on_primary" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/padding_medium">

            <!-- BASIC INFO Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/corner_radius"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_large">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="BASIC INFO"
                        android:textColor="@color/primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <!-- Outlet -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Outlet" android:textColor="@color/text_secondary" android:textSize="14sp" />
                        <TextView android:id="@+id/tvOutlet" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:gravity="end" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Description -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Description" android:textColor="@color/text_secondary" android:textSize="14sp" />
                        <TextView android:id="@+id/tvDescription" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:gravity="end" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Selling Price -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Selling Price" android:textColor="@color/text_secondary" android:textSize="14sp" />
                        <TextView android:id="@+id/tvPrice" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:gravity="end" android:textColor="@color/secondary" android:textSize="18sp" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- QOH -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/qoh" android:textColor="@color/text_secondary" android:textSize="14sp" />
                        <TextView android:id="@+id/tvQoh" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:gravity="end" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Min Qty -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Min Qty" android:textColor="@color/text_secondary" android:textSize="14sp" />
                        <TextView android:id="@+id/tvMinQty" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:gravity="end" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- PROMOTION Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_small"
                app:cardCornerRadius="@dimen/corner_radius"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_large">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="PROMOTION"
                        android:textColor="@color/primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <!-- Promo From -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Promo From" android:textColor="@color/text_secondary" android:textSize="14sp" />
                        <TextView android:id="@+id/tvPromoDateFrom" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:gravity="end" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Promo To -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Promo To" android:textColor="@color/text_secondary" android:textSize="14sp" />
                        <TextView android:id="@+id/tvPromoDateTo" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:gravity="end" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Promo Price -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Promo Price" android:textColor="@color/text_secondary" android:textSize="14sp" />
                        <TextView android:id="@+id/tvPromoPrice" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:gravity="end" android:textColor="#E65100" android:textSize="14sp" android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- PENDING PO Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_small"
                app:cardCornerRadius="@dimen/corner_radius"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_large">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="PENDING PO"
                        android:textColor="@color/primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <!-- Pending PO Qty -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Pending PO Qty" android:textColor="@color/text_secondary" android:textSize="14sp" />
                        <TextView android:id="@+id/tvQtyPo" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:gravity="end" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Pending CD Qty -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Pending CD Qty" android:textColor="@color/text_secondary" android:textSize="14sp" />
                        <TextView android:id="@+id/tvQtyReq" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:gravity="end" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Pending SP Qty -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Pending SP Qty" android:textColor="@color/text_secondary" android:textSize="14sp" />
                        <TextView android:id="@+id/tvQtyTbr" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:gravity="end" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SUPPLY INFO Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_small"
                app:cardCornerRadius="@dimen/corner_radius"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_large">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="SUPPLY INFO"
                        android:textColor="@color/primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <!-- Last GR Qty -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Last GR Qty" android:textColor="@color/text_secondary" android:textSize="14sp" />
                        <TextView android:id="@+id/tvLastGrQty" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:gravity="end" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Last GR Date -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Last GR Date" android:textColor="@color/text_secondary" android:textSize="14sp" />
                        <TextView android:id="@+id/tvLastGrDate" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:gravity="end" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Last GR Vendor -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Last GR Vendor" android:textColor="@color/text_secondary" android:textSize="14sp" />
                        <TextView android:id="@+id/tvLastGrVendor" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:gravity="end" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Last Vendor Name -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Last Vendor Name" android:textColor="@color/text_secondary" android:textSize="14sp" />
                        <TextView android:id="@+id/tvVendorName" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:gravity="end" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SKU INFO Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_small"
                app:cardCornerRadius="@dimen/corner_radius"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_large">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="SKU INFO"
                        android:textColor="@color/primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <!-- Barcode -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Barcode" android:textColor="@color/text_secondary" android:textSize="14sp" />
                        <TextView android:id="@+id/tvBarcode" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:gravity="end" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Article Code -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Article Code" android:textColor="@color/text_secondary" android:textSize="14sp" />
                        <TextView android:id="@+id/tvArticleNo" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:gravity="end" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Item Status -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Item Status" android:textColor="@color/text_secondary" android:textSize="14sp" />
                        <TextView android:id="@+id/tvItemStatus" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:gravity="end" android:textSize="14sp" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Pack Size -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Pack Size" android:textColor="@color/text_secondary" android:textSize="14sp" />
                        <TextView android:id="@+id/tvPackSize" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:gravity="end" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Carton Qty -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Carton Qty" android:textColor="@color/text_secondary" android:textSize="14sp" />
                        <TextView android:id="@+id/tvBulkQty" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:gravity="end" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Dept -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Dept" android:textColor="@color/text_secondary" android:textSize="14sp" />
                        <TextView android:id="@+id/tvDepartment" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:gravity="end" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Sub Dept -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Sub Dept" android:textColor="@color/text_secondary" android:textSize="14sp" />
                        <TextView android:id="@+id/tvSubDepartment" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:gravity="end" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Category -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Category" android:textColor="@color/text_secondary" android:textSize="14sp" />
                        <TextView android:id="@+id/tvCategory" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:gravity="end" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- COST INFO Card (admin/buyer only - visibility controlled in code) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCostInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_small"
                app:cardCornerRadius="@dimen/corner_radius"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_large">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="COST INFO"
                        android:textColor="@color/primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <!-- FIFO Cost -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="FIFO Cost" android:textColor="@color/text_secondary" android:textSize="14sp" />
                        <TextView android:id="@+id/tvFifoCost" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:gravity="end" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Average Cost -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Average Cost" android:textColor="@color/text_secondary" android:textSize="14sp" />
                        <TextView android:id="@+id/tvAvgCost" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:gravity="end" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Last Cost -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Last Cost" android:textColor="@color/text_secondary" android:textSize="14sp" />
                        <TextView android:id="@+id/tvLastCost" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:gravity="end" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Print Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPrintLabel"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="@dimen/padding_large"
                android:text="@string/print_shelf_label"
                android:textSize="16sp"
                app:icon="@drawable/ic_print"
                app:iconGravity="textStart"
                app:cornerRadius="@dimen/corner_radius" />

            <!-- Scan Another Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnScanAnother"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="@dimen/padding_small"
                android:text="Scan Another"
                android:textSize="16sp"
                app:icon="@drawable/ic_barcode_scanner"
                app:iconGravity="textStart"
                app:cornerRadius="@dimen/corner_radius" />

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
